{
  "name": "ca-short",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"SERVER,VITE\" --prefix-colors \"cyan,green\" \"npm run server\" \"vite --host 0.0.0.0\"",
    "server": "nodemon server/server.cjs",
    "server:prod": "node server/server.cjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:prod": "vite preview --host 0.0.0.0 --port 5173",
    "prod": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"cyan,green\" \"npm run server:prod\" \"npm run preview:prod\"",
    "start:prod": "npm run build && npm run prod"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
